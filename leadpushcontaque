                    DateTime dt =ld.createddate;
                    String sfdate = dt.format('yyyy-MM-dd HH:mm:ss');
                    for(Duplicate_Lead_Sources__c dl:ld.Duplicate_Lead_Sources__r){
                        activityLogs.API_Request__c='leadId=='+ld.id+'\n';

                        activityLogs.API_Request__c=activityLogs.API_Request__c+'\n'+'Response:::::::{'+'campName:'+ld.Course_School__c+';'+'phone1:'+ld.MobilePhone+','+'listName:'+Lead_Push_Priority_Levels__c.getInstance('Priority 9').Priority_Level__c+','+
                                'skillName:'+Lead_Push_Priority_Levels__c.getInstance('Priority 9').Skill__c+','+'sfdate:'+sfdate+'status:'+ld.Status+'lead source:'+ld.Lead_Source_1__c+'data_source:'+ld.Data_Source1__c+'CreatedDate:'+dl.Created_date_and_time__c+'other source name:'+dl.Name+'}';

                        dataList.add(new LeadPushDataToCTI(
                            (ld.Course_School__c!=null && ld.Course_School__c!='')?ld.Course_School__c:System.Label.Contaque_Lead_Push_Unknown_School_Campaign,
                            ld.mobilephone.right(10),
                            Lead_Push_Priority_Levels__c.getInstance('Priority 9').Priority_Level__c,
                            Lead_Push_Priority_Levels__c.getInstance('Priority 9').Skill__c,
                            sfdate,
                            dl.Name,
                            dl.Data_Source__c,
                            dl.Created_date_and_time__c,
                            dl.Status__c,
                            dl.Lead_Source_Name__c
                            )
                        );
                        system.debug(' dataList'+ dataList);
                        ld.Posted_date__C=Date.Today();
                        activityLogs.Activityid__c=Lead_Push_Priority_Levels__c.getInstance('Priority 9').Priority_Level__c;
                        ld.CTI_Priority__c='p9';

                    }//duplicate source loop

                }// for loop for leadpush




            }// LeadPush if

            String endpintUrl;
            String username;
            String password;
             if([SELECT IsSandbox FROM Organization LIMIT 1].IsSandbox){
                endpintUrl = configdata.Dialer_Sand_bulk_lead_push_endp__c;
                username=configdata.Dialer_Sandb_Verve_Username__c;
                password=configdata.Dialer_Sandb_Verve_Pass__c;

            }else//prod
            {
                endpintUrl = configdata.Dialer_Prod_bulk_lead_push_endp__c;
                username=configdata.Dialer_User_Name_Prod__c;
                password=configdata.Dialer_Password_Prod__c;

            }
            if(!dataList.isEmpty()){


                Http h=new Http();
                HttpRequest req=new HttpRequest();
                req.setTimeout(120000);

                req.setEndpoint(endpintUrl);
                req.setMethod('POST');
                req.setHeader('Content-Type', 'application/json');
                system.debug('PK checking req reenquire  '+ JSON.serialize(dataList));
                req.setBody(JSON.serialize(dataList));

                // Set up Basic Authorization header new

                Blob headerValue = Blob.valueOf(username + ':' + password);
                String authorizationHeader = 'Basic ' + EncodingUtil.base64Encode(headerValue);
                req.setHeader('Authorization', authorizationHeader);
                activityLogs.Json_Request__c = JSON.serialize(dataList);

                try{
                    httpresponse res= h.send(req);
                    if(res.getStatusCode()==200)
                    {
                        activityLogs.API_Response__c=res.getBody();
                        insert activityLogs;
                        update leadPush;
                        system.debug('try reenq '+ leadPush);

                    }else{
                        activityLogs.API_Response__c=res.getBody();
                        activityLogs.Status__c = 'ANP Lead Push error';
                        insert activityLogs;
                        //Send mail
                        if(configdata.Send_Dialer_error_mail__c){
                            activityLogs = NotificationAlertError.sendEmailNotification(activityLogs , 'Response is not 200 ', res.getStatusCode() + ' @ ' + res.getBody() );
                        }
                    }
                }catch(Exception e){
                    system.debug('catch reenq + ' + leadPush);
                    //update leadPush; // for testing
                    activityLogs.Status__c = 'ANP Lead Push error';
                    activityLogs.API_Response__c=e.getMessage();
                    //sned mail
                    if(configdata.Send_Dialer_error_mail__c){
                        activityLogs = NotificationAlertError.sendEmailNotification(activityLogs ,  'Exception occured in dialer integration UPES ',  e.getMessage() );
                    }
                    insert activityLogs;
                }


            }//end of if datalist


        } // end of if run anp
    } //End of method


